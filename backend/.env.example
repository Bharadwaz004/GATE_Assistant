# Application
APP_NAME=GATE Study Planner
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gate_planner
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/gate_planner

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Hugging Face
HF_MODEL_NAME=google/flan-t5-large
HF_API_TOKEN=your-huggingface-token
HF_USE_API=true
HF_API_URL=https://api-inference.huggingface.co/models

# Sentence Transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
